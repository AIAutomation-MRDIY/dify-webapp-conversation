# ===== Dify =====
# APP ID
NEXT_PUBLIC_APP_ID=
# APP API key
NEXT_PUBLIC_APP_KEY=
# API url prefix, e.g. https://api.dify.ai/v1 or your self-hosted Dify API
NEXT_PUBLIC_API_URL=

# ===== Lark authentication =====
# App ID / App Secret from Lark Developer Console (https://open.larksuite.com)
LARK_APP_ID=
LARK_APP_SECRET=
# 'larksuite' (international, default) or 'feishu' (China)
LARK_DOMAIN=larksuite
# Random long string used to sign the session cookie (e.g. `openssl rand -hex 32`)
SESSION_SECRET=
# Optional: only allow users from this tenant (tenant_key from Lark)
LARK_TENANT_KEY=
# Optional: set to 'true' to only allow access from inside the Lark app (blocks normal browsers)
LARK_CLIENT_ONLY=false
# Optional: session lifetime in seconds (default 43200 = 12h)
SESSION_TTL=43200
# Optional: public base URL of the deployment, e.g. https://your-app.vercel.app
# If unset, it is derived from the request headers (works on Vercel).
APP_BASE_URL=
